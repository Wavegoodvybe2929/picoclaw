{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "current-context.schema.json",
  "title": "Current Context Schema",
  "description": "Schema for short-term session context",
  "type": "object",
  "required": ["meta", "context"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["created", "updated", "version", "session_id"],
      "properties": {
        "created": {"type": "string", "format": "date-time"},
        "updated": {"type": "string", "format": "date-time"},
        "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
        "session_id": {"type": "string"}
      }
    },
    "context": {
      "type": "object",
      "required": ["active_branch"],
      "properties": {
        "active_branch": {"type": "string"},
        "current_task": {"type": ["string", "null"]},
        "active_agents": {
          "type": "array",
          "items": {"type": "string"}
        },
        "recent_files": {
          "type": "array",
          "items": {"type": "string"}
        },
        "conversation_summary": {"type": "string"}
      }
    }
  }
}
